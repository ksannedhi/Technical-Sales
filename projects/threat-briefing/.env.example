ANTHROPIC_API_KEY=your_anthropic_api_key_here
OTX_API_KEY=your_otx_api_key_here
PORT=3003
PUPPETEER_EXECUTABLE_PATH=

# Pins the Node.js process clock to Kuwait time so the daily cron fires at
# 06:00 AST regardless of what timezone the host machine is set to.
# Safe to leave set on any OS — does not affect the briefing content.
TZ=Asia/Kuwait
