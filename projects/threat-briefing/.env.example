ANTHROPIC_API_KEY=your_anthropic_api_key_here
OTX_API_KEY=your_otx_api_key_here
ABUSECH_API_KEY=your_abusech_api_key_here
PORT=3003
PUPPETEER_EXECUTABLE_PATH=

# Pins the Node.js process clock to Kuwait time so the daily cron fires at
# 06:00 AST regardless of what timezone the host machine is set to.
# Safe to leave set on any OS — does not affect the briefing content.
TZ=Asia/Kuwait

# ── Public deployment (Railway + Vercel) ─────────────────────────────────────

# Restrict CORS to your Vercel frontend URL. Comma-separate multiple origins.
# Leave unset to allow all origins (local dev default).
ALLOWED_ORIGIN=

# Protect the /api/briefing/generate endpoint from public abuse.
# Set to any random string. If set, POST /generate requires:
#   Authorization: Bearer <your-secret>
# Leave unset to allow unauthenticated generation (local dev default).
GENERATE_SECRET=

# Railway-specific: path to Chromium installed via nixpacks.
# Set this in Railway environment variables:
#   PUPPETEER_EXECUTABLE_PATH=/nix/var/nix/profiles/default/bin/chromium
#   PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_SKIP_DOWNLOAD=
