# Anthropic API key — required for executive narrative generation
# Without this, scoring and roadmap still work; narrative section is omitted
ANTHROPIC_API_KEY=your_key_here

# Claude model used for narrative generation (defaults to claude-haiku-4-5-20251001 for speed)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: override Puppeteer Chrome path if auto-detection fails
# Local Windows only — not needed on Railway (uses bundled Chromium automatically)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Backend port (default 3005)
# Railway injects PORT automatically — do not set this in Railway env vars
PORT=3005

# Frontend origin for CORS
# Local dev: http://localhost:5180
# Railway (single-service): not needed — frontend and API share the same origin
# Railway (two-service): set to your Railway frontend URL
CORS_ORIGIN=http://localhost:5180
